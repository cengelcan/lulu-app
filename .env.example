# Supabase — Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional — password reset redirect override (mainly for Expo Go testing).
# Copy the URL shown in the dev alert after "Forgot password?", or use tunnel mode.
# Supabase Dashboard → Auth → URL Configuration → Redirect URLs must include:
#   exp://**
#   luluapp://reset-password
# EXPO_PUBLIC_AUTH_REDIRECT_URL=exp://192.168.1.10:8081/--/reset-password

# RevenueCat — Project Settings → API Keys (public iOS key)
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_xxxxxxxx

# Dev-only: bypass Plus gating (family sharing, limits). Never enable in production.
# EXPO_PUBLIC_PLUS_DEV_BYPASS=true
# Legacy alias (still supported):
# EXPO_PUBLIC_FAMILY_SHARING_DEV_BYPASS=true

# Google Sign-In — Google Cloud Console → Credentials
# Web client ID: koda ve Supabase Google provider'a girilir (signInWithIdToken doğrulaması bununla yapılır)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=YOUR-WEB-CLIENT-ID.apps.googleusercontent.com
# iOS client ID: GoogleSignin iOS yapılandırması için
EXPO_PUBLIC_GOOGLE_IOS_CLIENT_ID=YOUR-IOS-CLIENT-ID.apps.googleusercontent.com
